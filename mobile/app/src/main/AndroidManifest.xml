<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required for Retrofit/OkHttp to reach the backend API -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".core.AppointMedApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppointMed"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true">

        <!-- Splash is the first screen the user sees; it hands off to Login -->
        <activity
            android:name=".features.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AppointMed.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".features.auth.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.AppointMed" />

        <activity
            android:name=".features.auth.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.AppointMed" />

        <activity
            android:name=".features.patient.DashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.AppointMed" />
        <activity
            android:name=".features.doctor.DoctorDashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.AppointMed" />
        <activity
            android:name=".features.admin.AdminDashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.AppointMed" />

    </application>

</manifest>