<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:maxHeight="520dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Patients get a reminder email this many hours before their appointment. At least one offset is required."
            android:textColor="@color/ink_soft"
            android:textSize="12.5sp" />

        <TextView
            android:id="@+id/tvReminderLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading…"
            android:textColor="@color/ink_soft"
            android:textSize="13.5sp" />

        <LinearLayout
            android:id="@+id/reminderContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvNoReminderOffsets"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No reminder offsets configured."
                android:textColor="@color/ink_soft"
                android:textSize="13sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvReminderOffsets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:hint="Hours before (1–168)">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNewReminderOffset"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btnAddReminderOffset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/stamp"
                    android:textColor="#FFFFFF" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvReminderActionError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/danger"
                android:textSize="12.5sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnSaveReminderSchedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Save schedule"
                android:textAllCaps="false"
                android:backgroundTint="@color/stamp"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tvReminderSaveMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/ink_soft"
                android:textSize="12.5sp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
