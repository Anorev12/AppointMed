<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/paper"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reschedule appointment"
            android:textColor="@color/ink"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRescheduleCurrent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="14dp"
            android:textColor="@color/ink_soft"
            android:textSize="13sp"
            tools:text="Currently: Dr. Reyes · 2026-07-10 · 09:00" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New date"
            android:textColor="@color/ink"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etRescheduleDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="10dp"
            android:background="@color/paper_card"
            android:clickable="true"
            android:cursorVisible="false"
            android:focusable="false"
            android:padding="12dp"
            android:textColor="@color/ink" />

        <TextView
            android:id="@+id/tvRescheduleSlotsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New time"
            android:textColor="@color/ink"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRescheduleSlotsLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Loading…"
            android:textColor="@color/ink_soft"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvRescheduleSlotsError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/danger"
            android:visibility="gone"
            tools:text="This doctor has no open hours on that day." />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRescheduleSlots"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvRescheduleError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/danger"
            android:visibility="gone"
            tools:text="This appointment can no longer be changed." />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnRescheduleCancel"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Close" />

            <Button
                android:id="@+id/btnRescheduleConfirm"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:enabled="false"
                android:text="Confirm move" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>