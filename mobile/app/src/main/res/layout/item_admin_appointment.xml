<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/paper_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvAdminAptPatient"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/ink"
                android:textSize="14.5sp"
                android:textStyle="bold"
                tools:text="Juan Dela Cruz" />

            <TextView
                android:id="@+id/tvAdminAptStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="Confirmed" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvAdminAptDoctor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/ink_soft"
            android:textSize="12.5sp"
            tools:text="Dr. Reyes" />

        <TextView
            android:id="@+id/tvAdminAptDateTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/ink_soft"
            android:textSize="12.5sp"
            tools:text="2026-07-10 · 09:00" />

        <TextView
            android:id="@+id/tvAdminAptRef"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="monospace"
            android:textColor="@color/ink_soft"
            android:textSize="11.5sp"
            tools:text="APT-102938" />

        <Button
            android:id="@+id/btnOverrideCancel"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Override cancel"
            android:textAllCaps="false"
            android:textColor="@color/danger"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>