<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/paper_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvPatientNameAdmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ink"
            android:textSize="14.5sp"
            android:textStyle="bold"
            tools:text="Juan Dela Cruz" />

        <TextView
            android:id="@+id/tvPatientEmailAdmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/ink_soft"
            android:textSize="12.5sp"
            tools:text="juan.delacruz@email.com" />

        <TextView
            android:id="@+id/tvPatientContactAdmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/ink_soft"
            android:textSize="12.5sp"
            tools:text="0917 123 4567" />

        <Button
            android:id="@+id/btnViewHistory"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="View history"
            android:textAllCaps="false"
            android:textColor="@color/stamp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>